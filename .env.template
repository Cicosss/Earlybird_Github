# ============================================
SUPABASE_URL=your_supabase_url_here      # https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here      # anon/public key from Supabase dashboard
SUPABASE_CACHE_TTL_SECONDS=300            # Cache TTL in seconds (default: 300 = 5 minutes)

# ============================================
# SHARED CONTENT CACHE (V14.0 - Cross-Component Deduplication)
# ============================================
# Maximum entries per cache (content, URL, simhash) before LRU eviction
# Total memory footprint: SHARED_CACHE_MAX_ENTRIES * 3 * ~100 bytes
# Examples:
#   5000  = ~1.5MB (default, recommended for VPS with 1-2GB RAM)
#   10000 = ~3MB (original value, may cause OOM on resource-constrained VPS)
#   2000  = ~0.6MB (for VPS with 512MB RAM)
SHARED_CACHE_MAX_ENTRIES=5000             # Default: 5000 (reduced from 10000 for VPS compatibility)

# ============================================
# OPTIONAL: VERIFICATION LAYER
# ============================================
# Enable/disable verification layer (default: true)
VERIFICATION_ENABLED=true

# ============================================
# OPTIONAL: CONTRACT VALIDATION (V14.0)
# ============================================
# Enable/disable contract validation between components (default: true)
# When disabled, only basic checks (None, non-dict) are performed
# When enabled, full field validation with detailed logging is performed
CONTRACT_VALIDATION_ENABLED=true

# ============================================
# OPTIONAL: LOGGING
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# ============================================
# BACKGROUND SERVICES CONTROL
# ============================================
# Runtime control for background services to manage VPS resources
# All services are enabled by default (True) unless explicitly disabled (False)
BROWSER_MONITOR_ENABLED=True    # Browser Monitor service
NEWS_RADAR_ENABLED=True         # News Radar service
HEALTH_MONITOR_ENABLED=True     # Health Monitor service

# ============================================
# NITTER FALLBACK SCRAPER CONFIGURATION
# ============================================
# Configuration for Nitter fallback scraper (third-tier Twitter intel recovery)
NITTER_MAX_RETRIES=3            # Maximum retry attempts per account (default: 3)
MAX_NITTER_RECOVERY_ACCOUNTS=10 # Maximum accounts to recover via Nitter (default: 10)

# ============================================
# ORCHESTRATION METRICS (V11.1 - System Monitoring)
# ============================================
# Metrics alert thresholds (default values shown)
METRICS_CPU_THRESHOLD=80.0                # CPU usage alert threshold (%)
METRICS_MEMORY_THRESHOLD=85.0             # Memory usage alert threshold (%)
METRICS_DISK_THRESHOLD=90.0               # Disk usage alert threshold (%)
METRICS_RETENTION_DAYS=7                  # Days to keep metrics data

# Lock contention alert thresholds
LOCK_CONTENTION_TIMEOUT_THRESHOLD=10        # Number of timeouts before alert
LOCK_CONTENTION_WAIT_TIME_THRESHOLD=0.5     # Average wait time before alert (seconds)
LOCK_CONTENTION_ALERT_THROTTLE_MINUTES=5  # Minimum time between same alert (minutes)

# ============================================
# PLAYWRIGHT BROWSER INSTALLATION (VPS DEPLOYMENT)
# ============================================
# IMPORTANT: After running 'pip install -r requirements.txt', you MUST also run:
#   playwright install chromium
# This installs the actual browser binaries required by Playwright.
# Without this step, the bot will crash with "Executable doesn't exist" error.
# The playwright Python package (in requirements.txt) only provides the Python API,
# not the browser binaries themselves.

ENV_TYPE=TEMPLATE_ONLY_READ_REAL_ENV

